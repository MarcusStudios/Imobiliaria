rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /{allPaths=**} {
      // Leitura pública de imagens
      allow read: if true;

      // Escrita restrita ao Admin:
      // UID: UG2t4JLe6WgzQShgaBP83EfXgfy1 (atualizar em SETUP.md se mudar)
      // Validações: apenas imagens, máximo 10MB
      allow write: if request.auth != null
                   && request.auth.uid == "UG2t4JLe6WgzQShgaBP83EfXgfy1"
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
